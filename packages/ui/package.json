{
  "name": "@quiz-mcp/ui",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./i18n": {
      "types": "./dist/lib/i18n.d.ts",
      "import": "./dist/lib/i18n.js"
    },
    "./i18n-svelte": {
      "types": "./dist/lib/i18n-svelte.d.ts",
      "svelte": "./src/lib/i18n-svelte.ts",
      "import": "./dist/lib/i18n-svelte.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "echo 'lint ok'",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@quiz-mcp/core": "workspace:*",
    "daisyui": "^5",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "svelte": "^5",
    "typescript": "^5.8",
    "vitest": "^2"
  }
}
